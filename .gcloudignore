# Controls what `gcloud run deploy --source .` uploads to Cloud Build.
# Only the analytics API (analytics-api/main.py + requirements.txt), the UI (public/),
# and the Dockerfile are needed. Everything below is excluded.

.git/
.gitignore
.gcloudignore
.dockerignore
.claude/
.firebase/
.firebaserc
firebase.json
deploy.sh
.DS_Store
**/.DS_Store

# Docs & scripts — not needed inside the container
*.md
*.gs

# UI build SOURCES — not served. The built bundles live in public/ (React
# dashboard at public/, Matter Node/Thread at public/matter/), which IS uploaded.
# Excluding the sources keeps the upload tiny.
matter-ui/
web/

# Python virtualenv, caches, and Node modules
analytics-api/venv/
**/__pycache__/
**/*.pyc
**/node_modules/
