# Controls what `gcloud run deploy --source .` uploads to Cloud Build.
# Only the analytics API (analytics-api/main.py + requirements.txt), the UI (public/),
# and the Dockerfile are needed. Everything below is excluded.

.git/
.gitignore
.gcloudignore
.dockerignore
.claude/
.firebase/
.firebaserc
firebase.json
deploy.sh
.DS_Store
**/.DS_Store

# Docs & scripts — not needed inside the container
*.md
*.gs

# Matter UI build SOURCE — not served. The built bundle lives in public/matter/
# (which IS uploaded). Excluding the source keeps the upload tiny.
matter-ui/

# Python virtualenv, caches, and Node modules
analytics-api/venv/
**/__pycache__/
**/*.pyc
**/node_modules/
